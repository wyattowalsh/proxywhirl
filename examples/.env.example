# Example .env file for docker-compose
# Copy to .env and adjust values for your environment

# Redis Configuration
REDIS_PASSWORD=redis-dev-pass

# Database Configuration
DB_USER=proxywhirl
DB_PASSWORD=proxywhirl-dev

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=admin

# ProxyWhirl API Configuration
PROXYWHIRL_API_KEY=your-secret-api-key-here
PROXYWHIRL_LOG_LEVEL=INFO

# Proxy Sources
# Enable specific proxy sources (optional)
# ENABLE_FREE_PROXY_LIST=true
# ENABLE_PROXY_SCRAPER_API=true
