{
	"name": "proxywhirl-web",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"packageManager": "pnpm@10.13.1",
	"scripts": {
		"dev": "next dev",
		"docs:generate": "node scripts/generate-docs.mjs && node scripts/generate-openapi-docs.mjs && node scripts/generate-llms.mjs",
		"prebuild": "pnpm run docs:generate",
		"build": "NODE_OPTIONS=--disable-warning=DEP0205 next build",
		"start": "next start",
		"lint": "eslint . --max-warnings 0",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "NODE_OPTIONS=--disable-warning=DEP0205 playwright test",
		"test:e2e:ci": "CI=1 NODE_OPTIONS=--disable-warning=DEP0205 playwright test"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.20",
		"@radix-ui/react-dropdown-menu": "^2.1.21",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-tabs": "^1.1.18",
		"@tanstack/react-virtual": "^3.14.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"fumadocs-core": "^16.11.5",
		"fumadocs-mdx": "^15.2.0",
		"fumadocs-openapi": "^10.9.0",
		"fumadocs-ui": "^16.11.5",
		"lucide-react": "^0.469.0",
		"motion": "^12.42.2",
		"next": "^16.2.10",
		"next-themes": "^0.4.6",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-globe.gl": "^2.27.2",
		"react-simple-maps": "^3.0.0",
		"recharts": "^2.15.0",
		"shiki": "^4.3.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^2.6.0",
		"three": "^0.185.1",
		"topojson-client": "^3.1.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.6",
		"@next/eslint-plugin-next": "^16.2.10",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "^4.3.3",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/mdx": "^2.0.14",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.0.2",
		"@types/three": "^0.185.1",
		"@types/topojson-client": "^3.1.5",
		"autoprefixer": "^10.5.4",
		"eslint": "^9.39.1",
		"eslint-config-next": "^16.2.10",
		"jsdom": "^27.4.0",
		"postcss": "^8.5.20",
		"tailwindcss": "^4.3.3",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.7.2",
		"vitest": "^4.1.10"
	}
}
